{
  "name": "gmail-mcp",
  "version": "0.1.0",
  "description": "A read-only Gmail MCP server using Google's official googleapis SDK",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "gmail-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/auth.ts --",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "private": true,
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "googleapis": "^144.0.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
